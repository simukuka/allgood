EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Rafiki GraphQL Backend - https://rafiki.dev/apis/graphql/backend/
# Public client endpoint. For Vercel web deployment this should remain /api/rafiki.
EXPO_PUBLIC_RAFIKI_PROXY_URL=/api/rafiki
# Optional direct endpoint fallback (development only; prefer proxy in production)
EXPO_PUBLIC_RAFIKI_GRAPHQL_URL=https://your-rafiki-backend.example.com/graphql
# Base domain for wallet payment pointers (e.g. https://ilp.your-domain.com)
# Wallets are provisioned at: $RAFIKI_WALLET_DOMAIN/users/$userId
EXPO_PUBLIC_RAFIKI_WALLET_DOMAIN=https://ilp.your-domain.com

# Server-side only secrets for Vercel Functions (DO NOT prefix with EXPO_PUBLIC_)
RAFIKI_GRAPHQL_URL=https://your-rafiki-backend.example.com/graphql
RAFIKI_API_KEY=your_rafiki_admin_api_secret
RAFIKI_TENANT_ID=your_tenant_id
RAFIKI_SIGNATURE_VERSION=1

# Legacy REST relay (deprecated — kept for reference only)
EXPO_PUBLIC_RAFIKI_API_URL=https://your-rafiki-relay.example.com
EXPO_PUBLIC_RAFIKI_PUBLISHABLE_KEY=your_rafiki_publishable_key

# Real money funding rails (Stripe)
# Toggle real funding mode in the app
EXPO_PUBLIC_REAL_BANKING_ENABLED=false
# Public app URL used for Stripe success/cancel redirects
EXPO_PUBLIC_APP_URL=https://allgood-kappa.vercel.app
# Server-side only Stripe + Supabase admin secrets (Vercel env vars)
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_...
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
